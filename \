#include <stdio.h>

#define MAX(a,b) (a)>(b)?(a):(b)

void solve()
{
    int n;
    scanf("%d",&n);
    char s[n];
    int ones = 0, zeros = 0;
    int sum1 =0, sum0 = 0 ;
    for (int i = 0; i < n; i++)
    {
        scanf(" %c",&s[i]);
        if (s[i] == '1')
        {
            sum1++;
        }
        else {
            ones = MAX(ones,sum1);
            sum1 = 0;
        }
        if (s[i] == '0')
        {
            sum0++;
        }
        else {
            zeros = MAX(zeros, sum0);
            sum0 = 0;
        }
    }        

    int xy = ones * zeros;
    int x2 = ones * ones;
    int y2 = zeros * zeros;
    int ans = MAX(xy, MAX(x2,y2));
    printf("%d\n",ans);
}

int main()
{
    int t;
    scanf("%d",&t);
    while (t--)
    {
        solve();
    }
    return 0;
}
